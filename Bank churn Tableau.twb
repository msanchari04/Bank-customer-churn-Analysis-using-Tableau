      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.00yfmcm101khq21dcq11i0qkjf46].[ctd:customer_id:qk]&quot;' value='Total Customers' />
          <alias key='&quot;[federated.00yfmcm101khq21dcq11i0qkjf46].[sum:active_member:qk]&quot;' value='Active Customers' />
        </aliases>
      </column>
      <column caption='Churn Rate%' datatype='real' name='[Calculation_0576475129761792]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [churn]= 1 &#13;&#10;THEN [customer_id] END)/ COUNTD([customer_id])' />
      </column>
      <column caption='Income Segment' datatype='string' name='[Calculation_0769164867694592]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [estimated_salary] &lt;  20000 THEN &quot;Basic&quot; &#13;&#10;ELSEIF [estimated_salary] &lt;= 100000 THEN &quot;Premium&quot; ELSE &quot;Elite&quot; END' />
      </column>
      <column caption='Customer Income segment' datatype='string' name='[Calculation_0769164938895361]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [estimated_salary] &lt; 20000 Then &quot;Basic&quot; &#13;&#10;ELSEIF [estimated_salary] &lt;= 100000 &#13;&#10;Then &quot;Premium&quot; else &quot;Elite&quot; END' />
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_1015455699308544]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [age] &lt;= 25 then &quot;Young Adult&quot; &#13;&#10;ELSEIF [age] &lt;= 35 then &quot;Early Career&quot; &#13;&#10;ELSEIF [age] &lt;=45 then &quot;Mid Career&quot;&#13;&#10;ELSEIF [age] &lt;= 55 then &quot;Experienced&quot;&#13;&#10;elseif [age] &lt;= 62 then &quot;Senior&quot; &#13;&#10;ELSE &quot;Retired&quot; END' />
      </column>
      <column caption='Age Range' datatype='string' name='[Calculation_1015455716769793]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [age] &lt;=25 Then &quot;18-25&quot;&#13;&#10;elseif [age] &lt;=35 Then &quot;26-35&quot;&#13;&#10;elseif [age] &lt;=45 Then &quot;36-45&quot;&#13;&#10;elseif [age] &lt;=55 Then &quot;46-55&quot;&#13;&#10;elseif [age] &lt;= 62 Then &quot;56-62&quot; &#13;&#10;ELSE &quot;63-92&quot;&#13;&#10;END' />
      </column>
      <column caption='Customer Credit Score ' datatype='string' name='[Calculation_1015455730737154]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='If [credit_score] &lt;= 580 Then &quot;High Risk&quot;&#13;&#10;elseif [credit_score] &lt;= 669 Then &quot;Medium Risk&quot;&#13;&#10;elseif [credit_score] &lt;= 739 Then &quot;Low Risk&quot;&#13;&#10;elseif [credit_score] &lt;= 799 Then &quot;Secure&quot;&#13;&#10;else &quot;Prime&quot; END' />
      </column>
      <column caption='Credit Score Range' datatype='string' name='[Calculation_1015455732817924]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='If [credit_score] &lt;= 580 Then &quot;&lt;580&quot;&#13;&#10;elseif [credit_score] &lt;= 669 Then &quot;581-669&quot;&#13;&#10;elseif [credit_score] &lt;= 739 Then &quot;670-739&quot;&#13;&#10;elseif [credit_score] &lt;= 799 Then &quot;740-799&quot;&#13;&#10;else &quot;800-850&quot; END' />
      </column>
      <column caption='Active' datatype='integer' name='[Calculation_1215566895869952]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF[churn] =0 Then 1&#13;&#10;else 0 END)' />
      </column>
      <column caption='Inactive' datatype='integer' name='[Calculation_1215566901833730]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF[churn] =1 Then 1&#13;&#10;else 0 END)' />
      </column>
